# =============================================================================
# The Global Staring Contest — Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=noblink

# ── Redis ────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── ML / Blink Detection ────────────────────────────────────────────────────
# Eye Aspect Ratio threshold — below this = eyes closing (default: 0.21)
EAR_THRESHOLD=0.21
# Consecutive frames below threshold to confirm a blink (default: 2)
EAR_CONSEC_FRAMES=2

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ───────────────────────────────────────────────────────────────────
APP_NAME="The Global Staring Contest"
DEBUG=true
